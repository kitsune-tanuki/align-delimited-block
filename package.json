{
  "name": "align-delimited-block",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.2.0",
  "publisher": "kitsune-tanuki",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "keywords": [
    "align",
    "table",
    "formatter",
    "text",
    "delimiter",
    "asciidoc",
    "latex",
    "tex",
    "columns",
    "markdown"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kitsune-tanuki/align-delimited-block.git"
  },
  "homepage": "https://github.com/kitsune-tanuki/align-delimited-block",
  "bugs": {
    "url": "https://github.com/kitsune-tanuki/align-delimited-block/issues"
  },
  "activationEvents": [
    "onCommand:alignDelimitedBlock.align",
    "onCommand:alignDelimitedBlock.alignWithPrompt"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "alignDelimitedBlock.align",
        "title": "%command.align.title%",
        "category": "%command.category%"
      },
      {
        "command": "alignDelimitedBlock.alignWithPrompt",
        "title": "%command.alignWithPrompt.title%",
        "category": "%command.category%"
      }
    ],
    "keybindings": [
      {
        "command": "alignDelimitedBlock.align",
        "key": "ctrl+shift+a",
        "when": "editorTextFocus"
      },
      {
        "command": "alignDelimitedBlock.alignWithPrompt",
        "key": "ctrl+alt+a",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "alignDelimitedBlock.defaultDelimiter": {
          "type": "string",
          "default": "|",
          "description": "%config.defaultDelimiter.description%"
        },
        "alignDelimitedBlock.markdownTableCenterHeader": {
          "type": "boolean",
          "default": false,
          "description": "%config.markdownTableCenterHeader.description%"
        }
      }
    }
  }
}
