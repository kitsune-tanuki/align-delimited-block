{
  "name": "align-delimited-block",
  "displayName": "Align Delimited Block",
  "description": "Align text blocks using delimiters like |, &, => or custom input. Useful for AsciiDoc tables, LaTeX align environments and general text formatting.",
  "version": "0.1.2",
  "publisher": "kitsune-tanuki",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "keywords": [
    "align",
    "table",
    "formatter",
    "text",
    "delimiter",
    "asciidoc",
    "latex",
    "tex",
    "columns"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kitsune-tanuki/align-delimited-block.git"
  },
  "homepage": "https://github.com/kitsune-tanuki/align-delimited-block",
  "bugs": {
    "url": "https://github.com/kitsune-tanuki/align-delimited-block/issues"
  },
  "activationEvents": [
    "onCommand:alignDelimitedBlock.align",
    "onCommand:alignDelimitedBlock.alignWithPrompt"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "alignDelimitedBlock.align",
        "title": "Align Delimited Block (Default Delimiter)",
        "category": "Align Delimited Block"
      },
      {
        "command": "alignDelimitedBlock.alignWithPrompt",
        "title": "Align Delimited Block (Custom Delimiter)",
        "category": "Align Delimited Block"
      }
    ],
    "keybindings": [
      {
        "command": "alignDelimitedBlock.align",
        "key": "ctrl+shift+a",
        "when": "editorTextFocus"
      },
      {
        "command": "alignDelimitedBlock.alignWithPrompt",
        "key": "ctrl+alt+a",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Align Delimited Block",
      "properties": {
        "alignDelimitedBlock.defaultDelimiter": {
          "type": "string",
          "default": "|",
          "description": "Default delimiter used by Align Delimited Block (Ctrl+Shift+A)"
        },
        "alignDelimitedBlock.markdownTableCenterHeader": {
          "type": "boolean",
          "default": false,
          "description": "Center-align the Markdown table header row instead of following the separator alignment"
        }
      }
    }
  }
}
